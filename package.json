{
  "name": "crud-api",
  "version": "1.0.0",
  "description": "Simple CRUD API for a Product Catalog using an in-memory database",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:dev": "tsx watch src/server.ts",
    "start:prod": "npm run build && node dist/server.js",
    "test": "vitest run"
  },
  "keywords": [
    "crud",
    "api",
    "fastify",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.6.1",
    "fastify": "^5.8.2",
    "uuid": "^11.1.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.0",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
